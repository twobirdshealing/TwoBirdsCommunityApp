{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_SITE_URL": "https://staging.twobirdschurch.com",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_ORG": "$SENTRY_ORG",
        "SENTRY_PROJECT": "$SENTRY_PROJECT",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_SITE_URL": "https://community.twobirdschurch.com",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_ORG": "$SENTRY_ORG",
        "SENTRY_PROJECT": "$SENTRY_PROJECT",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "simulator": {
      "developmentClient": false,
      "channel": "simulator",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_SITE_URL": "https://community.twobirdschurch.com",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_ORG": "$SENTRY_ORG",
        "SENTRY_PROJECT": "$SENTRY_PROJECT",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    },
    "production": {
      "autoIncrement": false,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_SITE_URL": "https://community.twobirdschurch.com",
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_ORG": "$SENTRY_ORG",
        "SENTRY_PROJECT": "$SENTRY_PROJECT",
        "SENTRY_ALLOW_FAILURE": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jay@twobirdshealing.org",
        "ascAppId": "1563113528"
      }
    }
  }
}
