# EAS Build — file filtering (replaces .gitignore when EAS_NO_VCS=1)
# This is the source of truth. Keep .gitignore in sync with this file.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Not part of the app — excluded from EAS builds
setup/
scripts/
companion plugins/
website/
.claude/
.vscode/
CLAUDE.md
CHANGELOG.md
README.md
FIREBASE_SETUP.md
manifest.json

# junk
nul
